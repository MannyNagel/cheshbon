{
  "expo": {
    "name": "Daily Cheshbon",
    "slug": "daily-cheshbon",
    "scheme": "dailycheshbon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/daily-cheshbon-logo.png",
    "splash": {
      "image": "./assets/daily-cheshbon-logo-title.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/daily-cheshbon-logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/daily-cheshbon-logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ]
  }
}
